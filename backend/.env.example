APP_NAME=WeFindBest AI API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
DATABASE_URL=postgresql+psycopg2://admin:admin@127.0.0.1:5433/wefindbest
SECRET_KEY=change-this-local-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
DEFAULT_USER_QUOTA=1000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AI_GATEWAY_DEFAULT_PROVIDER=mock
AI_GATEWAY_DEFAULT_MODEL=mock
AI_GATEWAY_FALLBACK_MODELS=mock
AI_GATEWAY_LOAD_BALANCING=round_robin
AI_GATEWAY_MAX_RETRIES=2
AI_GATEWAY_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_API_KEY=
